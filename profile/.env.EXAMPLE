# Environment variables required by this Hermes distribution.
# Copy to `.env` and fill in your own values before running.

# OpenRouter API key for the default model provider.
# Required.
OPENROUTER_API_KEY=

# Readonly Kubernetes MCP auth token.
# Required.
MCP_AUTH_TOKEN=

# Local OpenAI-compatible LLM endpoint, for example llama.cpp / llama-server.
# Optional. Use explicitly with `/model custom:llmcpp:${LOCAL_LLM_MODEL}`.
LOCAL_LLM_BASE_URL=http://localhost:8080/v1
LOCAL_LLM_MODEL=
