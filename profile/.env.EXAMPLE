# Environment variables required by this Hermes distribution.
# Copy to `.env` and fill in your own values before running.

# OpenRouter API key for model access.
# Required.
OPENROUTER_API_KEY=

# Telegram gateway bot token.
# Required for Telegram gateway usage.
TELEGRAM_BOT_TOKEN=

# Telegram user allowlist.
# Required for Telegram gateway usage.
TELEGRAM_ALLOWED_USERS=

# Slack gateway bot token.
# Required for Slack gateway usage.
SLACK_BOT_TOKEN=

# Slack app-level token for Socket Mode.
# Required for Slack gateway usage.
SLACK_APP_TOKEN=

# Slack member ID allowlist.
# Required for Slack gateway usage.
SLACK_ALLOWED_USERS=

# Slack channel ID allowlist.
# Optional. Leave empty to allow all channels where the bot is invited.
SLACK_ALLOWED_CHANNELS=

# Slack channel ID for proactive gateway and scheduled delivery messages.
# Optional.
SLACK_HOME_CHANNEL=

# Readonly Kubernetes MCP auth token.
# Required.
MCP_AUTH_TOKEN=

# Readonly Kubernetes MCP endpoint and allowed Host header.
# Required.
KUBERNETES_MCP_URL=http://mcp-server-kubernetes.hermes-sre.svc.cluster.local:3001/mcp
